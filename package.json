{
  "name": "shepherd",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "shepherd": "./dist/src/cli/shepherd.js"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.18.0",
    "pnpm": ">=11.9.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "check": "pnpm typecheck && pnpm test && pnpm lint && pnpm format:check && pnpm db:check",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.17.0",
    "ai": "^6.0.208",
    "ai-sdk-provider-codex-cli": "^1.2.2",
    "ajv": "^8.20.0",
    "drizzle-orm": "^0.45.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^24.13.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
